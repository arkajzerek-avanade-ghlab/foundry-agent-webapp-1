{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.42.1.51946",
      "templateHash": "7812960074033089022"
    }
  },
  "parameters": {
    "location": {
      "type": "string"
    },
    "tags": {
      "type": "object"
    },
    "resourceToken": {
      "type": "string"
    },
    "containerAppsEnvironmentId": {
      "type": "string"
    },
    "containerRegistryName": {
      "type": "string"
    },
    "aiAgentEndpoint": {
      "type": "string"
    },
    "entraSpaClientId": {
      "type": "string"
    },
    "entraTenantId": {
      "type": "string"
    },
    "entraBackendClientId": {
      "type": "string",
      "defaultValue": ""
    },
    "webImageName": {
      "type": "string"
    },
    "userAssignedIdentityId": {
      "type": "string",
      "defaultValue": ""
    },
    "oboManagedIdentityClientId": {
      "type": "string",
      "defaultValue": ""
    },
    "appInsightsConnectionString": {
      "type": "string",
      "defaultValue": ""
    },
    "appInsightsFrontendConnectionString": {
      "type": "string",
      "defaultValue": ""
    }
  },
  "variables": {
    "$fxv#0": {
      "resourcesResourceGroups": "rg-",
      "containerRegistryRegistries": "cr",
      "appManagedEnvironments": "cae-",
      "appContainerApps": "ca-",
      "operationalInsightsWorkspaces": "law-",
      "insightsComponents": "appi-",
      "managedIdentityUserAssignedIdentities": "id-"
    },
    "abbrs": "[variables('$fxv#0')]",
    "baseEnv": [
      {
        "name": "ASPNETCORE_ENVIRONMENT",
        "value": "Production"
      },
      {
        "name": "ASPNETCORE_URLS",
        "value": "http://+:8080"
      },
      {
        "name": "ENTRA_SPA_CLIENT_ID",
        "value": "[parameters('entraSpaClientId')]"
      },
      {
        "name": "ENTRA_TENANT_ID",
        "value": "[parameters('entraTenantId')]"
      },
      {
        "name": "AI_AGENT_ENDPOINT",
        "value": "[parameters('aiAgentEndpoint')]"
      },
      {
        "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
        "value": "[parameters('appInsightsConnectionString')]"
      },
      {
        "name": "APPLICATIONINSIGHTS_FRONTEND_CONNECTION_STRING",
        "value": "[parameters('appInsightsFrontendConnectionString')]"
      }
    ],
    "miEnv": [
      {
        "name": "MANAGED_IDENTITY_CLIENT_ID",
        "value": "[parameters('oboManagedIdentityClientId')]"
      }
    ],
    "oboEnv": "[if(not(empty(parameters('entraBackendClientId'))), createArray(createObject('name', 'ENTRA_BACKEND_CLIENT_ID', 'value', parameters('entraBackendClientId'))), createArray())]",
    "containerEnv": "[concat(variables('baseEnv'), variables('miEnv'), variables('oboEnv'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "web-container-app",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "name": {
            "value": "[format('{0}web-{1}', variables('abbrs').appContainerApps, parameters('resourceToken'))]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "tags": {
            "value": "[union(parameters('tags'), createObject('azd-service-name', 'web'))]"
          },
          "containerAppsEnvironmentId": {
            "value": "[parameters('containerAppsEnvironmentId')]"
          },
          "containerRegistryName": {
            "value": "[parameters('containerRegistryName')]"
          },
          "containerImage": {
            "value": "[parameters('webImageName')]"
          },
          "targetPort": {
            "value": 8080
          },
          "env": {
            "value": "[variables('containerEnv')]"
          },
          "enableIngress": {
            "value": true
          },
          "external": {
            "value": true
          },
          "healthProbePath": {
            "value": "/api/health"
          },
          "userAssignedIdentityId": {
            "value": "[parameters('userAssignedIdentityId')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.42.1.51946",
              "templateHash": "8114354499712425098"
            }
          },
          "parameters": {
            "name": {
              "type": "string"
            },
            "location": {
              "type": "string"
            },
            "tags": {
              "type": "object"
            },
            "containerAppsEnvironmentId": {
              "type": "string"
            },
            "containerRegistryName": {
              "type": "string"
            },
            "containerImage": {
              "type": "string"
            },
            "targetPort": {
              "type": "int"
            },
            "env": {
              "type": "array",
              "defaultValue": []
            },
            "enableIngress": {
              "type": "bool",
              "defaultValue": true
            },
            "external": {
              "type": "bool",
              "defaultValue": true
            },
            "healthProbePath": {
              "type": "string",
              "defaultValue": ""
            },
            "cpu": {
              "type": "string",
              "defaultValue": "0.5"
            },
            "memory": {
              "type": "string",
              "defaultValue": "1Gi"
            },
            "minReplicas": {
              "type": "int",
              "defaultValue": 0
            },
            "maxReplicas": {
              "type": "int",
              "defaultValue": 3
            },
            "userAssignedIdentityId": {
              "type": "string"
            }
          },
          "resources": [
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "identity": {
                "type": "UserAssigned",
                "userAssignedIdentities": {
                  "[format('{0}', parameters('userAssignedIdentityId'))]": {}
                }
              },
              "properties": {
                "managedEnvironmentId": "[parameters('containerAppsEnvironmentId')]",
                "configuration": {
                  "activeRevisionsMode": "Single",
                  "ingress": "[if(parameters('enableIngress'), createObject('external', parameters('external'), 'targetPort', parameters('targetPort'), 'transport', 'auto', 'allowInsecure', false()), null())]",
                  "registries": [
                    {
                      "server": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('containerRegistryName')), '2023-07-01').loginServer]",
                      "identity": "[if(not(empty(parameters('userAssignedIdentityId'))), parameters('userAssignedIdentityId'), 'system')]"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "[parameters('name')]",
                      "image": "[parameters('containerImage')]",
                      "env": "[parameters('env')]",
                      "resources": {
                        "cpu": "[json(parameters('cpu'))]",
                        "memory": "[parameters('memory')]"
                      },
                      "probes": "[if(not(empty(parameters('healthProbePath'))), createArray(createObject('type', 'Liveness', 'httpGet', createObject('path', parameters('healthProbePath'), 'port', parameters('targetPort')), 'periodSeconds', 30, 'failureThreshold', 3), createObject('type', 'Startup', 'httpGet', createObject('path', parameters('healthProbePath'), 'port', parameters('targetPort')), 'periodSeconds', 10, 'failureThreshold', 30, 'initialDelaySeconds', 5)), createArray())]"
                    }
                  ],
                  "scale": {
                    "minReplicas": "[parameters('minReplicas')]",
                    "maxReplicas": "[parameters('maxReplicas')]"
                  }
                }
              }
            }
          ],
          "outputs": {
            "id": {
              "type": "string",
              "value": "[resourceId('Microsoft.App/containerApps', parameters('name'))]"
            },
            "name": {
              "type": "string",
              "value": "[parameters('name')]"
            },
            "fqdn": {
              "type": "string",
              "value": "[if(parameters('enableIngress'), reference(resourceId('Microsoft.App/containerApps', parameters('name')), '2024-03-01').configuration.ingress.fqdn, '')]"
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "webEndpoint": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Resources/deployments', 'web-container-app'), '2025-04-01').outputs.fqdn.value)]"
    },
    "webAppName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'web-container-app'), '2025-04-01').outputs.name.value]"
    }
  }
}